# ISSUE-006 spike — webhook forgery / replay (AF-078).
#
# TWO MODES. The harness picks the mode by which vars are present (src/config.ts):
#
#   MODE M (mechanics) — NO env needed. Fully self-contained: the harness generates
#     its own Slack signing secret, a throwaway Ed25519 keypair to SIMULATE GHL's
#     signer, and a local JWKS to mint/verify Google JWTs. Proves the parse-before-
#     verify crux, constant-time compare, and replay defense. It does NOT resolve
#     AF-090 (the real GHL signing base string) — MODE M prints that debt loudly and
#     REFUSES to claim AF-078 GREEN.
#
#   MODE R (real / you-present) — the operator supplies a LIVE captured GHL webhook
#     payload + GHL's real published Ed25519 public key. Only then does the harness
#     resolve AF-090 (confirm the real GHL signing base string against the real key)
#     and assert the verifiers against REAL vendor signatures. AF-078 only flips GREEN
#     in MODE R with the GHL path proven against real GHL facts ("don't fake infra").
#
# Copy this file to `.env` and fill in the MODE-R values you have. `.env` is gitignored.

# ── GHL (REQUIRED for MODE R — resolves AF-090; NOT self-signable) ───────────────
# Path to a LIVE captured GHL webhook request, as a JSON file with this shape:
#   { "rawBody": "<exact received bytes, verbatim — NOT re-serialised>",
#     "headers": { "x-ghl-signature": "<sig>", "x-wh-signature": "<legacy, if any>",
#                  "x-ghl-timestamp": "<if GHL sends one>", ... } }
# The rawBody MUST be the exact bytes GHL sent (capture before any JSON parse) or the
# signature will not verify — that is the whole failure mode this spike exists to catch.
GHL_WEBHOOK_PAYLOAD_FILE=

# GHL's published Ed25519 public key (PEM, SPKI) and the primary-source URL it came from.
# The verifier reads the key from the webhook_secrets sink, never inline. Recorded into the
# AF-090 register row on resolution.
GHL_PUBLIC_KEY=
GHL_PUBLIC_KEY_URL=

# ── Slack (OPTIONAL — self-signable in MODE M) ───────────────────────────────────
# Providing a real Slack signing secret lets you assert against a real Slack payload.
# Without it, MODE M generates its own secret and self-signs the valid case.
SLACK_SIGNING_SECRET=

# ── Google (OPTIONAL — self-mintable in MODE M) ──────────────────────────────────
# A real Google Pub/Sub push JWT (the bearer token from the Authorization header) plus
# the audience it was minted for. Without these, MODE M mints its own JWT against a local
# JWKS with the spike-local expected audience.
GOOGLE_PUSH_JWT=
GOOGLE_EXPECTED_AUDIENCE=
