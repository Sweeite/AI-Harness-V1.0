# ISSUE-005 spike — operator-provided values (AF-077 gate).
#
# This is an R8 "YOU-PRESENT" spike: it drives a REAL scripted attack against a REAL
# Supabase Auth project. Every value below must be provided by the operator; the harness
# hard-codes NONE of them and REFUSES TO RUN if the required ones are absent (never a
# silent pass with no target — #3). Use a THROWAWAY, DISPOSABLE project — the harness
# fires hundreds of failed logins and will trip Supabase's IP rate limits.

# --- The attack target: a throwaway Supabase Auth project -------------------
# Supabase → Project Settings → API. Use a project you can delete afterwards.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service-role key — used ONLY to read auth state / confirm no session was minted and to
# reset the seeded account between batteries. NEVER exposed to the attack path itself.
SUPABASE_SERVICE_ROLE_KEY=

# Plan tier: free | pro (or higher). Leaked-password protection is PRO+ ONLY. On `free`,
# AC-0.AUTH.009.2's leaked-password half can only be asserted as config-INTENDED, not
# enforced — the evidence records that distinction honestly. Pro+ is required for a full
# GREEN on the leaked-password control.
SUPABASE_PLAN=free
# Whether leaked-password protection is actually TURNED ON in the dashboard (Supabase →
# Authentication → Attack Protection). Only enforce-able on Pro+. The harness asserts
# AC-0.AUTH.009.2's leaked-password half against this flag (config-intended on `free`).
LEAKED_PASSWORD_PROTECTION=false

# --- The seeded external-Super-Admin test account (the attack's single target) ----
# One account enrolled with email+password AND a TOTP factor (build order §8.1).
TEST_ACCOUNT_EMAIL=
TEST_ACCOUNT_PASSWORD=
# The enrolled TOTP factor's base32 secret — lets the harness generate real WRONG codes
# (to drive the mfa_softlock_threshold path) and the one RIGHT code (to prove the correct
# code is refused once the challenge is soft-locked). Supabase has NO dashboard button for
# this — enrollment is a client-SDK flow. After the user exists (email+password) and TOTP is
# enabled on the project, run `npm run enroll` (src/enroll.ts): it enrolls + activates the
# factor and PRINTS this line for you to paste back here.
TEST_ACCOUNT_TOTP_SECRET=

# --- CAPTCHA (hCaptcha / Turnstile) — dashboard-configured on the Auth form -------
# Set true once you've turned CAPTCHA on in Supabase → Authentication → Attack Protection.
CAPTCHA_ENABLED=false
# Provider test keys make the CAPTCHA-present assertion REAL (providers publish
# always-pass / always-fail test keys). hCaptcha always-pass sitekey/secret or Turnstile
# equivalents. Leave blank to assert CAPTCHA presence as config-intended only.
# CAPTCHA_PROVIDER=hcaptcha
# CAPTCHA_TEST_SITEKEY=
# CAPTCHA_TEST_SECRET=

# --- Multi-IP battery source (optional) -----------------------------------------
# TRUE multi-IP requires real egress proxies the harness cannot assume. If you provide a
# comma-separated list of proxy endpoints, battery (b) runs REAL requests through them
# (mode = real-proxy). If BLANK, battery (b) runs the SIMULATED mode: it disables the
# harness per-IP counter to prove the per-account soft-lock + CAPTCHA + leaked-password
# are the real backstop when IP limits alone are defeated. The evidence LABELS which mode
# actually ran.
# PROXY_ENDPOINTS=http://user:pass@proxy1:8080,http://user:pass@proxy2:8080

# --- Spike soft-lock thresholds (contestable-by-design; see src/config.ts) --------
# The spec names these CFG-auth params but sets no hard constant. These are sensible spike
# defaults; the CONFIRMED values the build should adopt are recorded in the evidence.
# ACCOUNT_LOCKOUT_THRESHOLD=5
# ACCOUNT_LOCKOUT_MINUTES=15
# MFA_SOFTLOCK_THRESHOLD=5
# ATTACK_PASSWORD_ATTEMPTS=200
