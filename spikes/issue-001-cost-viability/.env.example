# ISSUE-001 cost-viability spike — vendor credentials.
# Copy to `.env` (gitignored) and fill in. The spike makes REAL paid calls.
#
# Anthropic — Sonnet (reasoning/writer) + Haiku (classification/gate/pre-checks).
ANTHROPIC_API_KEY=

# OpenAI — text-embedding-3-small (memory embeddings).
OPENAI_API_KEY=

# Model ids (override if the deployment pins different snapshots).
# Defaults match ADR-003's Sonnet-reasoning / Haiku-classification split.
ANTHROPIC_SONNET_MODEL=claude-sonnet-5
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5-20251001
OPENAI_EMBED_MODEL=text-embedding-3-small
